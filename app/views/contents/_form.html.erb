<%= form_with model: [@creator, @content], class: "space-y-6" do |f| %>
  <%# Error Summary %>
  <% if @content.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <h3 class="text-sm font-medium text-red-800">
        <%= pluralize(@content.errors.count, "error") %> prevented this content from being saved:
      </h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700 space-y-1">
        <% @content.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title Field %>
  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-900 mb-1" %>
    <%= f.text_field :title,
          class: "w-full rounded-lg border #{@content.errors[:title].any? ? 'border-red-500' : 'border-gray-300'} bg-white px-4 py-2.5 text-gray-900 placeholder-gray-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors",
          placeholder: "Enter content title" %>
    <% if @content.errors[:title].any? %>
      <p class="mt-1 text-sm text-red-600"><%= @content.errors[:title].first %></p>
    <% end %>
  </div>

  <%# URL Field %>
  <div>
    <%= f.label :social_media_url, "URL", class: "block text-sm font-medium text-gray-900 mb-1" %>
    <%= f.url_field :social_media_url,
          class: "w-full rounded-lg border #{@content.errors[:social_media_url].any? ? 'border-red-500' : 'border-gray-300'} bg-white px-4 py-2.5 text-gray-900 placeholder-gray-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors",
          placeholder: "https://example.com/content" %>
    <% if @content.errors[:social_media_url].any? %>
      <p class="mt-1 text-sm text-red-600"><%= @content.errors[:social_media_url].first %></p>
    <% end %>
  </div>

  <%# Provider Field %>
  <div>
    <%= f.label :social_media_provider, "Provider", class: "block text-sm font-medium text-gray-900 mb-1" %>
    <%= f.select :social_media_provider,
          options_for_select(
            Content.social_media_providers.keys.map { |p| [p.titleize, p] },
            @content.social_media_provider
          ),
          { include_blank: "Select a provider" },
          class: "w-full rounded-lg border #{@content.errors[:social_media_provider].any? ? 'border-red-500' : 'border-gray-300'} bg-white px-4 py-2.5 text-gray-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors" %>
    <% if @content.errors[:social_media_provider].any? %>
      <p class="mt-1 text-sm text-red-600"><%= @content.errors[:social_media_provider].first %></p>
    <% end %>
  </div>

  <%# Buttons %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "rounded-lg bg-blue-600 px-5 py-2.5 text-white font-medium hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors cursor-pointer" %>
    <%= link_to "Cancel",
          creator_path(@creator),
          class: "rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-gray-700 font-medium hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors" %>
  </div>
<% end %>
