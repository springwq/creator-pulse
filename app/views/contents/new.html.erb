<div class="max-w-3xl mx-auto">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to creator_path(@creator), class: "inline-flex items-center text-sm text-blue-600 hover:text-blue-500 font-medium transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Creator
    <% end %>
  </div>

  <!-- Title -->
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Content</h1>

  <!-- Form -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-6">
    <%= render "form" %>
  </div>
</div>
