<!-- Back Link -->
<div class="mb-6">
  <%= link_to creators_path, class: "inline-flex items-center text-sm text-blue-600 hover:text-blue-500 font-medium transition-colors" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Creators
  <% end %>
</div>

<!-- Grid Layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <!-- Left Sidebar -->
  <div class="lg:col-span-3">
    <div class="lg:sticky lg:top-8">
      <!-- Creator Info Card -->
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-6 mb-4">
        <h1 class="text-xl font-bold text-gray-900"><%= @creator.name %></h1>
        <p class="mt-1 text-sm text-gray-500"><%= @creator.email %></p>

        <div class="mt-4 space-y-2 text-sm text-gray-500">
          <div class="flex justify-between">
            <span>Joined</span>
            <span class="text-gray-900 font-medium"><%= @creator.created_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex justify-between">
            <span>Contents</span>
            <span class="text-gray-900 font-medium"><%= @creator.contents.count %></span>
          </div>
        </div>
      </div>

      <!-- Add Content Button -->
      <%= link_to "Add Content",
            new_creator_content_path(@creator),
            class: "block w-full text-center rounded-lg bg-blue-600 px-4 py-2.5 text-white font-medium hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors" %>
    </div>
  </div>

  <!-- Right Content -->
  <div class="lg:col-span-9">
    <!-- Provider Filter -->
    <div class="mb-6">
      <%= form_with url: creator_path(@creator), method: :get, local: true, class: "flex items-center gap-3" do |f| %>
        <div class="flex-1 sm:flex-none">
          <%= f.select :provider,
                options_for_select(
                  [["All Providers", ""], ["Instagram", "instagram"], ["TikTok", "tiktok"], ["YouTube", "youtube"]],
                  params[:provider]
                ),
                {},
                class: "w-full sm:w-auto rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-gray-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors" %>
        </div>
        <%= f.submit "Filter",
              class: "rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-gray-700 font-medium hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <!-- Content List -->
    <% if @contents.any? %>
      <div class="space-y-4 mb-8">
        <% @contents.each do |content| %>
          <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-5">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="text-base font-semibold text-gray-900 truncate"><%= content.title %></h3>
                  <%# Provider Badge %>
                  <% case content.social_media_provider %>
                  <% when "instagram" %>
                    <span class="inline-flex items-center rounded-full bg-pink-100 px-2.5 py-0.5 text-xs font-medium text-pink-800">Instagram</span>
                  <% when "tiktok" %>
                    <span class="inline-flex items-center rounded-full bg-gray-900 px-2.5 py-0.5 text-xs font-medium text-white">TikTok</span>
                  <% when "youtube" %>
                    <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">YouTube</span>
                  <% end %>
                </div>
                <p class="mt-1 text-sm text-gray-500">Added on <%= content.created_at.strftime("%b %d, %Y") %></p>
                <p class="mt-1 text-sm truncate">
                  <%= link_to content.social_media_url,
                        content.social_media_url,
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-500 transition-colors" %>
                </p>
              </div>

              <!-- Actions -->
              <div class="flex items-center gap-2 shrink-0">
                <%= link_to "Edit",
                      edit_creator_content_path(@creator, content),
                      class: "rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 font-medium hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 transition-colors" %>
                <%= button_to "Delete",
                      creator_content_path(@creator, content),
                      method: :delete,
                      data: { turbo_confirm: "Are you sure?" },
                      class: "rounded-lg bg-red-600 px-3 py-1.5 text-sm text-white font-medium hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-600 transition-colors" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Pagination -->
      <div class="flex justify-center">
        <%= paginate @contents %>
      </div>
    <% else %>
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-12 text-center">
        <p class="text-gray-500 text-lg">No content found.</p>
        <p class="text-gray-400 text-sm mt-1">Add your first content to get started.</p>
      </div>
    <% end %>
  </div>
</div>
